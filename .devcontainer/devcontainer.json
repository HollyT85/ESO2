{
	"name": "ESO2",
	"image": "mcr.microsoft.com/devcontainers/python:3.12",
	"workspaceFolder": "/workspaces/ESO2",
	"postCreateCommand": "pip install -r requirements.txt",
	"customizations": {
		"vscode": {
			"settings": {
				"python.defaultInterpreterPath": "/usr/local/bin/python"
			},
			"extensions": [
				"ms-python.python"
			]
		}
	}
}
